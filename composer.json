{
  "name": "contributte/forms-bootstrap",
  "type": "library",
  "description": "Nette extension for Bootstrap forms",
  "homepage": "https://github.com/contributte/forms-bootstrap",
  "license": "MIT",
  "keywords": [
    "nette",
    "forms",
    "library",
    "bootstrap"
  ],
  "authors": [
    {
      "name": "Dalibor Korpar",
      "email": "dalibor.korpar@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "nette/application": "^3.0.0",
    "nette/forms": "^3.2.7"
  },
  "require-dev": {
    "contributte/phpstan": "~0.2.0",
    "contributte/qa": "~0.4.0",
    "contributte/tester": "~0.3.0",
    "mockery/mockery": "^1.6.12"
  },
  "autoload": {
    "psr-4": {
      "Contributte\\FormsBootstrap\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.9.x-dev"
    }
  }
}
